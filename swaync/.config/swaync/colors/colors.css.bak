@define-color center-bg                 #16161d;
@define-color notification-bg           #11111b;
@define-color center-notification-bg    #101014;
@define-color background                rgba(8, 8, 11, 0.9);
@define-color background-alt            #101014;
@define-color text                      #c0caf5;
@define-color text-alt                  #828282;
@define-color selected                  alpha(@text-alt, .4);
@define-color hover                     alpha(@selected, .4);
@define-color urgent                    @text-alt;
@define-color border-blue               #89b4fa;
