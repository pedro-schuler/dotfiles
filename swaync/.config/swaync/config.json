{
  "$schema": "/etc/xdg/swaync/configschema.json",
  "positionX": "right",
  "positionY": "top",
  "cssPriority": "user",
  "control-center-width": 450,
  "control-center-height": 1033,
  "fit-to-screen": false,

  "notification-window-width": 400,
  "notification-icon-size": 40,
  "notification-body-image-height": 500,
  "notification-body-image-width": 500,
  "notification-inline-replies": true,
  "notification-2fa-action": false,

  "timeout": 7,
  "timeout-low": 4,
  "timeout-critical": 6,

  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,

  "control-center-margin-top": 10,
  "control-center-margin-bottom": 10,
  "control-center-margin-right": 10,

  "widgets": [
    "backlight",
    "volume",
    "mpris",
    "dnd",
    "notifications",
    "buttons-grid"
  ],

  "widget-config": {
    "title": {
      "text": "Notificações",
      "clear-all-button": true,
      "button-text": "󰆴 Limpar tudo"
    },
    "backlight": {
      "label": "󰃠",
      "slider": true,
      "min": 10
    },
    "volume": {
      "device": "default",
      "label": "",
      "slider": true
    },

    "dnd": {
      "text": "Não Perturbe"
    },

    "mpris": {
      "image-size": 100,
      "image-radius": 10,
      "autohide": false
    },

    "buttons-grid": {
      "actions": [
        {
          "label": "󰐥",
          "command": "/home/schuler/.config/nwg-bar/exitmenu.sh --shutdown"
        },
        {
          "label": "󰜉",
          "command": "/home/schuler/.config/nwg-bar/exitmenu.sh --reboot"
        },
        {
          "label": "󰌾",
          "command": "/home/schuler/.config/nwg-bar/exitmenu.sh --lock"
        },
        {
          "label": "󰍃",
          "command": "/home/schuler/.config/nwg-bar/exitmenu.sh --logout"
        },
        {
          "label": "󰕾",
          "command": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
          "type": "toggle"
        },
        {
          "label": "󰍬",
          "command": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
          "type": "toggle"
        },
        {
          "label": "󰖩",
          "command": "nm-connection-editor"
        }
      ]
    }
  }
}
